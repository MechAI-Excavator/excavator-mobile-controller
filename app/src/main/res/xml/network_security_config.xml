<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 天地图 JS API 与瓦片仍大量使用 HTTP；WebView 自 https 主文档加载时需明文 + 混合内容策略 -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">tianditu.gov.cn</domain>
        <domain includeSubdomains="true">tianditu.com</domain>
        <!-- 内网更新服务（HTTP） -->
        <domain includeSubdomains="true">192.168.20.145</domain>
        <!-- 本机调试：OkHttp/WebView 访问 http://localhost 或 http://127.0.0.1 需放行明文 -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- 模拟器访问宿主机 localhost -->
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
