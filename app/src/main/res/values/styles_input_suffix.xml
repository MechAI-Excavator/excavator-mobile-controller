<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="InputWithSuffixContainer">
        <item name="android:background">@drawable/level_input_bg</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

    <style name="InputWithSuffixContainer.Light">
        <item name="android:background">@drawable/edittext_light_bg</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

    <style name="InputWithSuffixContainer.LightCompact">
        <item name="android:background">@drawable/edittext_light_bg</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
    </style>

    <style name="InputWithSuffixValue">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:gravity">center_vertical|start</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
    </style>

    <style name="InputSuffixUnit">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_marginStart">6dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">#FF9CA3AF</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="InputSuffixUnit.Light">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_marginStart">6dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">#FF93C5FD</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="InputSuffixUnit.LightCompact">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">#FF93C5FD</item>
        <item name="android:textSize">11sp</item>
    </style>
</resources>
