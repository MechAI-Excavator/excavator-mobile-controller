<?xml version="1.0" encoding="utf-8"?>
<!-- 修坡作业设置 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F4FF"
    android:orientation="vertical">

    <!-- 顶部导航栏 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="#00000000"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:id="@+id/btnLevelBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/arrow_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="返回"
                android:textColor="#FF2563EB"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="修坡作业设置"
            android:textColor="#FF111827"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnLevelHelp"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/answer_icon" />

    </RelativeLayout>

    <!-- 主内容区：左 / 右 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="40dp"
        android:paddingTop="4dp"
        android:paddingEnd="40dp"
        android:paddingBottom="20dp"
        android:weightSum="100">

        <!-- ── 左侧面板 ── -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="14dp"
            android:layout_weight="50"
            android:background="@drawable/card_light_bg"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Step1 标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="Step 1 选择修坡类型"
                    android:textColor="#FF111827"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <!-- t1 -->
                    <LinearLayout
                        android:id="@+id/cardDitchSquare"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:background="@drawable/level_card_normal_bg"
                        android:clickable="true"
                        android:layout_marginBottom="8dp"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDitchSquare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="22dp"
                            android:text="上开口线"
                            android:textColor="#FF9CA3AF"
                            android:textSize="14dp" />

                        <ImageView
                            android:layout_width="151dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/slope_repair1" />

                    </LinearLayout>

                    <!-- t2 -->
                    <LinearLayout
                        android:id="@+id/cardDitchTrapezoid"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:background="@drawable/level_card_normal_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDitchTrapezoid"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="22dp"
                            android:text="下开口线"
                            android:textColor="#FF9CA3AF"
                            android:textSize="14dp" />

                        <ImageView
                            android:layout_width="151dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/slope_repair2" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- ── 右侧预览面板 ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="50"
            android:background="@drawable/card_light_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="预览"
                android:textColor="#FF111827"
                android:textSize="16sp"
                android:textStyle="bold" />
            
            <LinearLayout
                android:id="@+id/panelSlopePreview"
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgSlopePreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="-12dp"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/slope_repair_preview" />
            </LinearLayout>

            <!-- 下一步按钮 -->
            <TextView
                android:id="@+id/btnLevelNext"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/button_blue_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="下一步"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Step 进度（底部）：当前为第 1 步 -->
    <LinearLayout
        android:id="@+id/levelStepBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <View
            android:id="@+id/step1"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_active" />

        <Space
            android:layout_width="30dp"
            android:layout_marginEnd="0dp"
            android:layout_marginStart="0dp"
            android:layout_height="1dp" />

        <View
            android:id="@+id/step2"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_inactive" />


               <Space
            android:layout_width="30dp"
            android:layout_marginEnd="0dp"
            android:layout_marginStart="0dp"
            android:layout_height="1dp" />

        <View
            android:id="@+id/step3"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_inactive" />

               <Space
            android:layout_width="30dp"
            android:layout_marginEnd="0dp"
            android:layout_marginStart="0dp"
            android:layout_height="1dp" />

        <View
            android:id="@+id/step4"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_inactive" />

        <Space
            android:layout_width="30dp"
            android:layout_marginEnd="0dp"
            android:layout_marginStart="0dp"
            android:layout_height="1dp" />

        <View
            android:id="@+id/step5"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_inactive" />
    </LinearLayout>

</LinearLayout>
