<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF6F7FB"
    android:orientation="vertical">

    <!-- 顶部导航栏 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="#00000000"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:id="@+id/btnPrecheckBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/arrow_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="返回"
                android:textColor="#FF2563EB"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="作业前检查"
            android:textColor="#FF111827"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnLevelHelp"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/answer_icon" />

    </RelativeLayout>

    <!-- 主体居中卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="420dp"
            android:layout_height="match_parent"
            android:background="@drawable/card_light_bg"
            android:orientation="vertical"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            android:paddingTop="30dp"
            android:paddingBottom="26dp">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="任务信息"
                        android:textColor="#FF111827"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:background="@drawable/check_green_bg"
                                        android:gravity="center"
                                        android:text="✓"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:includeFontPadding="false" />

                            <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:text="辅助功能:"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />

                            <TextView
                                        android:id="@+id/tvPrecheckFeatureValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="修坡"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:background="@drawable/check_green_bg"
                                        android:gravity="center"
                                        android:text="✓"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:includeFontPadding="false" />

                            <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:text="修坡类型:"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />

                            <TextView
                                        android:id="@+id/tvPrecheckRepairTypeValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="上开口线"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:background="@drawable/check_green_bg"
                                        android:gravity="center"
                                        android:text="✓"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:includeFontPadding="false" />

                            <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:text="A点:"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />

                            <TextView
                                        android:id="@+id/tvPrecheckRefAValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="中斗尖"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:background="@drawable/check_green_bg"
                                        android:gravity="center"
                                        android:text="✓"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:includeFontPadding="false" />

                            <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:text="B点:"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />

                            <TextView
                                        android:id="@+id/tvPrecheckRefBValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="中斗尖"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:background="@drawable/check_green_bg"
                                        android:gravity="center"
                                        android:text="✓"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:includeFontPadding="false" />

                            <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:text="C点:"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />

                            <TextView
                                        android:id="@+id/tvPrecheckRefCValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="中斗尖"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:background="@drawable/check_green_bg"
                                        android:gravity="center"
                                        android:text="✓"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:includeFontPadding="false" />

                            <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:text="AB距离:"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />

                            <TextView
                                        android:id="@+id/tvPrecheckAbDistanceValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="0.00 m"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:background="@drawable/check_green_bg"
                                        android:gravity="center"
                                        android:text="✓"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:includeFontPadding="false" />

                            <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:text="AB点升降量:"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />

                            <TextView
                                        android:id="@+id/tvPrecheckAbLiftValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="0.00 m"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:background="@drawable/check_green_bg"
                                        android:gravity="center"
                                        android:text="✓"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:includeFontPadding="false" />

                            <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:text="AB高差:"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />

                            <TextView
                                        android:id="@+id/tvPrecheckAbHeightDiffValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="0.00 m"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:background="@drawable/check_green_bg"
                                        android:gravity="center"
                                        android:text="✓"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:includeFontPadding="false" />

                            <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:text="坡比:"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />

                            <TextView
                                        android:id="@+id/tvPrecheckSlopeRatioValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="1:--"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:background="@drawable/check_green_bg"
                                        android:gravity="center"
                                        android:text="✓"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:includeFontPadding="false" />

                            <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:text="垂高:"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />

                            <TextView
                                        android:id="@+id/tvPrecheckVerticalHeightValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="0.00 m"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:background="@drawable/check_green_bg"
                                        android:gravity="center"
                                        android:text="✓"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:includeFontPadding="false" />

                            <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:text="平距:"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />

                            <TextView
                                        android:id="@+id/tvPrecheckHorizontalDistanceValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="0.00 m"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:background="@drawable/check_green_bg"
                                        android:gravity="center"
                                        android:text="✓"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:includeFontPadding="false" />

                            <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:text="坡面方向:"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />

                            <TextView
                                        android:id="@+id/tvPrecheckSlopeDirectionValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="右侧"
                                        android:textColor="#FF111827"
                                        android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="22dp"
                        android:layout_marginBottom="18dp"
                        android:background="#FFE5E7EB" />

                    <!-- RTK -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/iconPrecheckRtk"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/check_green_bg"
                            android:gravity="center"
                            android:text="✓"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:includeFontPadding="false" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="RTK 状态:"
                                            android:textColor="#FF111827"
                                            android:textSize="13sp" />

                                        <TextView
                                            android:id="@+id/tvPrecheckRtkStatus"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="8dp"
                                            android:text="已连接"
                                            android:textColor="#FF22C55E"
                                            android:textSize="13sp" />
                            </LinearLayout>

                            <TextView
                                        android:id="@+id/tvPrecheckRtkDesc"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="当前信号良好，符合作业要求"
                                        android:textColor="#FF9CA3AF"
                                        android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- IMU -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/iconPrecheckImu"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/check_green_bg"
                            android:gravity="center"
                            android:text="✓"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:includeFontPadding="false" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="IMU 状态:"
                                            android:textColor="#FF111827"
                                            android:textSize="13sp" />

                                        <TextView
                                            android:id="@+id/tvPrecheckImuStatus"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="8dp"
                                            android:text="数据正常"
                                            android:textColor="#FF22C55E"
                                            android:textSize="13sp" />
                            </LinearLayout>

                            <TextView
                                        android:id="@+id/tvPrecheckImuDesc"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="IMU 数据已识别，数据正常"
                                        android:textColor="#FF9CA3AF"
                                        android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>


                </LinearLayout>
            </ScrollView>

            <!-- 底部按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnPrecheckPrev"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_outline_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="上一步"
                    android:textColor="#FF6B7280"
                    android:textSize="14sp" />

                <Space
                    android:layout_width="14dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/btnPrecheckStart"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_blue_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="开始作业"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Step 进度（底部）：第 4 步 -->
    <LinearLayout
        android:id="@+id/levelStepBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_active" />

        <Space android:layout_width="20dp" android:layout_height="1dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_active" />

        <Space android:layout_width="20dp" android:layout_height="1dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_active" />

        <Space android:layout_width="20dp" android:layout_height="1dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_active" />
    </LinearLayout>

</LinearLayout>

