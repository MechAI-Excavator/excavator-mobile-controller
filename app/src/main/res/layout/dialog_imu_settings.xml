<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1E1E1E"
    android:orientation="vertical">

    <!-- ── 标题栏 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FF272727"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚙  IMU 数值设置"
            android:textColor="#FFD700"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnImuDialogReset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="恢复默认"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- ── 分割线 ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF" />

    <!-- ── 主内容区：左图 + 右输入 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- 左侧：关节示意图 -->
        <LinearLayout
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:background="#FF181818"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/ivJointDiagram"
                android:layout_width="172dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="关节参数示意图"
                android:textColor="#66FFFFFF"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- 竖向分割线 -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#33FFFFFF" />

        <!-- 右侧：可滚动参数表 -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <!-- ═══ Section: IMU 安装偏移角 ═══ -->
                <TextView
                    style="@style/ImuSectionHeader"
                    android:text="📐  IMU 安装偏移角 (°)" />

                <include layout="@layout/item_imu_field"
                    android:id="@+id/rowBoomOffset" />
                <include layout="@layout/item_imu_field"
                    android:id="@+id/rowStickOffset" />
                <include layout="@layout/item_imu_field"
                    android:id="@+id/rowBucketOffset" />

                <!-- ═══ Section: 关节尺寸 ═══ -->
                <TextView
                    style="@style/ImuSectionHeader"
                    android:layout_marginTop="10dp"
                    android:text="📏  关节尺寸 (mm)" />

                <include layout="@layout/item_imu_field"
                    android:id="@+id/rowBoomLength" />
                <include layout="@layout/item_imu_field"
                    android:id="@+id/rowStickLength" />
                <include layout="@layout/item_imu_field"
                    android:id="@+id/rowBucketLength" />
                <include layout="@layout/item_imu_field"
                    android:id="@+id/rowBucketAngleOffset" />

                <!-- ═══ Section: 大臂油缸 ═══ -->
                <TextView
                    style="@style/ImuSectionHeader"
                    android:layout_marginTop="10dp"
                    android:text="🔩  大臂油缸 (mm)" />

                <include layout="@layout/item_imu_field" android:id="@+id/rowBoomL2" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowBoomL3" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowBoomL4" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowBoomL5" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowBoomL6" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowBoomL7" />

                <!-- ═══ Section: 小臂油缸 ═══ -->
                <TextView
                    style="@style/ImuSectionHeader"
                    android:layout_marginTop="10dp"
                    android:text="🔩  小臂油缸 (mm)" />

                <include layout="@layout/item_imu_field" android:id="@+id/rowStickL2" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowStickL3" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowStickL4" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowStickL5" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowStickL6" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowStickL7" />

                <!-- ═══ Section: 铲斗油缸 ═══ -->
                <TextView
                    style="@style/ImuSectionHeader"
                    android:layout_marginTop="10dp"
                    android:text="🔩  铲斗油缸 (mm)" />

                <include layout="@layout/item_imu_field" android:id="@+id/rowBucketL2" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowBucketL3" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowBucketL4" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowBucketL5" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowBucketL6" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowBucketL7" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowBucketL9" />
                <include layout="@layout/item_imu_field" android:id="@+id/rowBucketL10" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- ── 分割线 ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF" />

    <!-- ── 底部按钮 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#FF272727"
        android:gravity="center_vertical|end"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/btnImuDialogCancel"
            android:layout_width="100dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/button_dark_bg"
            android:text="取消"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnImuDialogSave"
            android:layout_width="120dp"
            android:layout_height="36dp"
            android:background="@drawable/button_gold_bg"
            android:text="保存并应用"
            android:textColor="#1A1A1A"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
