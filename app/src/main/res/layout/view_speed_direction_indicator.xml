<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:layout_height="82.22dp"
    tools:layout_width="91.11dp"
    tools:parentTag="android.widget.FrameLayout">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/speed_indicator_bg"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="2dp"
        android:paddingBottom="8dp">

        <!-- 左侧：下三角 / 横线 / 上三角，权重与间距可在 XML 调 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="38"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/speedArrowTop"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                tools:src="@drawable/gray_angle" />

            <View
                android:id="@+id/speedLine"
                android:layout_width="29dp"
                android:layout_height="4dp"
                android:layout_marginStart="4dp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/speed_indicator_line_inactive" />

            <ImageView
                android:id="@+id/speedArrowBottom"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                tools:src="@drawable/gray_angle" />
        </LinearLayout>

        <TextView
            android:id="@+id/speedValue"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="62"
            android:gravity="center"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>
</merge>
