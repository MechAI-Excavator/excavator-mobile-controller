<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1A1A1A">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="#FF222222">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← 返回"
            android:textColor="#FFD700"
            android:textSize="15sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚙ 设置"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- 占位，平衡返回按钮 -->
        <View
            android:layout_width="60dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 视频流设置卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark_bg"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📹 视频流设置"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RTSP 视频流地址"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etSettingsVideoUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="例如 rtsp://192.168.144.100:554/stream1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#FF666666"
                    android:background="@drawable/edittext_dark_bg"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:inputType="textUri"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3D 模型臂长比例（与主界面 Web 同步，1 = 默认）"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="大臂比例"
                    android:textColor="#CCCCCC"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/etArmBoomScale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="默认 1.0"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#FF666666"
                    android:background="@drawable/edittext_dark_bg"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionNext"
                    android:singleLine="true"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="小臂比例"
                    android:textColor="#CCCCCC"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/etArmStickScale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="默认 1.0"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#FF666666"
                    android:background="@drawable/edittext_dark_bg"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:layout_marginBottom="14dp" />

                <Button
                    android:id="@+id/btnSaveVideoUrl"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="保存并应用"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:background="@drawable/button_gold_bg" />
            </LinearLayout>

            <!-- IMU 数值设置卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark_bg"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📐 IMU 数值设置"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="配置大臂、小臂、铲斗的油缸尺寸及 IMU 安装偏移角，参数保存后立即生效。"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="大臂偏移"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvImuBoomOffsetPreview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFD580"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="小臂偏移"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvImuStickOffsetPreview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFD580"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="铲斗偏移"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvImuBucketOffsetPreview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFD580"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnOpenImuDialog"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/button_gold_bg"
                        android:text="配置 →"
                        android:textColor="#1A1A1A"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
