<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F2F5"
    android:orientation="vertical">

    <!-- ─── 顶部标题栏 ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFFFFFF"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <!-- CAPSTONE logo (same as view_header_bar.xml) -->
        <ImageView
            android:layout_width="116dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:scaleType="centerCrop"
            android:src="@drawable/black_logo"
            tools:ignore="ContentDescription" />

        <!-- "参数设置" label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="参数设置"
            android:textColor="#FF374151"
            android:textSize="14sp" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- 保存配置 button (top-right, blue gradient + icon) -->
        <LinearLayout
            android:id="@+id/btnSaveVideoUrl"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/button_blue_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/save_icon"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="保存配置"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ─── 主体：左侧导航 + 右侧内容 ─────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- ── 左侧导航面板 ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="205dp"
            android:layout_height="match_parent"
            android:background="#FFFFFFFF"
            android:elevation="1dp"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- 返回按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp">


                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/setting_back"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp"
                    android:text="返回"
                    android:textColor="#004DFF"
                    android:textSize="13sp" />
            </LinearLayout>


            <!-- 导航项 1：IMU 安装角度 -->
            <LinearLayout
                android:id="@+id/navImu"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/nav_item_selected_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <ImageView
                            android:layout_width="28.4dp"
                            android:layout_height="28.4dp"
                            android:layout_marginEnd="10.6dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/imu_setting_icon"
                            tools:ignore="ContentDescription" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IMU 安装角度"
                            android:textColor="#FF0C0C0C"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="偏差校准"
                            android:textColor="#FF7C7C7C"
                            android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

        
                </LinearLayout>
            </LinearLayout>

            <!-- 导航项 2：尺寸信息 -->
            <LinearLayout
                android:id="@+id/navDimensions"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <ImageView
                            android:layout_width="28.4dp"
                            android:layout_height="28.4dp"
                            android:layout_marginEnd="10.6dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/dimensions_setting_icon"
                            tools:ignore="ContentDescription" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="尺寸信息"
                            android:textColor="#FF0C0C0C"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="关节尺寸"
                            android:textColor="#FF7C7C7C"
                            android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

        
                </LinearLayout>
            </LinearLayout>

            <!-- 导航项 3：摇杆通道映射 -->
            <LinearLayout
                android:id="@+id/navJoystick"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                 <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <ImageView
                            android:layout_width="28.4dp"
                            android:layout_height="28.4dp"
                            android:layout_marginEnd="10.6dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/joystick_setting_icon"
                            tools:ignore="ContentDescription" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="摇杆通道映射"
                            android:textColor="#FF0C0C0C"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="控制方向配置"
                            android:textColor="#FF7C7C7C"
                            android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

        
                </LinearLayout>
            </LinearLayout>

            <!-- 导航项 4：通用设置 -->
            <LinearLayout
                android:id="@+id/navGeneral"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                  <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <ImageView
                            android:layout_width="28.4dp"
                            android:layout_height="28.4dp"
                            android:layout_marginEnd="10.6dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/common_setting_icon"
                            tools:ignore="ContentDescription" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="通用设置"
                            android:textColor="#FF0C0C0C"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="语言、显示与视频流"
                            android:textColor="#FF7C7C7C"
                            android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

        
                </LinearLayout>
            </LinearLayout>

            <!-- 弹性空白 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 重置为默认值 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:text="↺"
                    android:textColor="#FF9CA3AF"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="重置为默认值"
                    android:textColor="#FF9CA3AF"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── 右侧内容区：各 page 叠放，只有当前 page 可见 ──── -->
        <FrameLayout
            android:id="@+id/settingsContentFrame"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <include
                android:id="@+id/pageImu"
                layout="@layout/settings_page_imu"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible" />

            <include
                android:id="@+id/pageDimensions"
                layout="@layout/settings_page_dimensions"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <include
                android:id="@+id/pageJoystick"
                layout="@layout/settings_page_joystick"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <include
                android:id="@+id/pageGeneral"
                layout="@layout/settings_page_general"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

</LinearLayout>
