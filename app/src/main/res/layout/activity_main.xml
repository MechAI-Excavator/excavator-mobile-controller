<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ==================== 全屏视频层（底层背景） ==================== -->
    <eightbitlab.com.blurview.BlurTarget
        android:id="@+id/blurTarget"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF0A">

        <!-- 视频画面（16:9 居中全屏） -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.skydroid.fpvplayer.FPVWidget
                android:id="@+id/fpvWidget"
                android:layout_width="964dp"
                android:layout_height="598dp"
                android:background="#FF000000"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="16:9"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0"
                tools:ignore="ContentDescription">

                <FrameLayout
                    android:id="@+id/videoPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="visible">

                </FrameLayout>
            </com.skydroid.fpvplayer.FPVWidget>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@drawable/with_no_live_video" />

            <!-- 占位图放在 videoPlaceholder 内：离线 VISIBLE 时与壳一起显示；在线 GONE 时整层去掉，避免被空 Frame 盖在平板下不显示 -->


        </androidx.constraintlayout.widget.ConstraintLayout>

    </eightbitlab.com.blurview.BlurTarget>

    <!-- 姿态卡片右侧：LIVE 状态胶囊（与 postureCardBlur 顶对齐） -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/livePillBlur"
        android:layout_width="wrap_content"
        android:layout_height="16.66dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="210dp"
        android:layout_marginTop="85dp"
        android:background="@drawable/live_pill_bg"
        android:clipToOutline="true"
        android:elevation="8dp"
        android:outlineProvider="background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingTop="1dp"
            android:paddingEnd="10dp"
            android:paddingBottom="1dp">

            <View
                android:id="@+id/livePillDot"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/live_dot_red" />

            <TextView
                android:id="@+id/livePillText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:letterSpacing="0.02"
                android:text="实时"
                android:textColor="#FFFFFF"
                android:textSize="8sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:letterSpacing="0.02"
                android:text=" · 主相机"
                android:textColor="#7AFFFFFF"
                android:textSize="8sp" />

        </LinearLayout>

    </eightbitlab.com.blurview.BlurView>

    <!-- 左侧竖条 + 横向中心度量条（与姿态卡片顶对齐留白） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="start|top"
        android:orientation="horizontal">

        <com.capstone.excavator.LeftActivityPanelView
            android:layout_width="24.88dp"
            android:layout_height="match_parent" />

    </LinearLayout>


        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="33dp"
            android:layout_gravity="center_horizontal|top"
            android:layout_marginTop="55dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:src="@drawable/back_title" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="9.5dp"
                android:includeFontPadding="false"
                android:text="参考点: 中斗尖"
                android:textColor="#FFFFFF"
                android:textSize="6.5sp" />
        </FrameLayout>


    <com.capstone.excavator.CenterActivityPanelView
        android:id="@+id/centerActivityPanelView"
        android:layout_width="433dp"
        android:layout_height="20dp"
        android:layout_gravity="center|top"
        android:layout_marginTop="55dp"
        app:centerGaugeRangeMax="1" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="105dp"
        android:gravity="center_horizontal"
        android:orientation="horizontal">

        <com.capstone.excavator.CapsuleSpeedDirectionView
            android:id="@+id/centerCapsuleSpeedDirection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- ==================== 左侧覆盖层：机械臂姿态卡片（毛玻璃底） ==================== -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/postureCardBlur"
        android:layout_width="165dp"
        android:layout_height="165dp"
        android:layout_gravity="start|top"
        android:layout_marginStart="28.44dp"
        android:layout_marginTop="55dp"
        android:layout_marginBottom="0dp"
        android:background="@drawable/map_card_bg"
        android:clipToOutline="true"
        android:elevation="10dp"
        android:outlineProvider="background">

        <com.capstone.excavator.PostureCardView
            android:id="@+id/postureCardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </eightbitlab.com.blurview.BlurView>

    <!-- ==================== 右侧覆盖层：地图 + 驾驶舱状态（毛玻璃底） ==================== -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/rightPanelBlur"
        android:layout_width="165dp"
        android:layout_height="165dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="55dp"
        android:layout_marginEnd="28.44dp"
        android:layout_marginBottom="0dp"
        android:background="@drawable/map_card_bg"
        android:clipToOutline="true"
        android:elevation="10dp"
        android:outlineProvider="background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- 顶部标题行：地图 + 收起箭头 -->
            <LinearLayout
                android:id="@+id/rightPanelHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/map_title"
                    android:textColor="#FFFFFF"
                    android:textFontWeight="200"
                    android:textSize="11sp" />

                <ImageView
                    android:id="@+id/rightPanelCollapseArrow"
                    android:layout_width="10.66dp"
                    android:layout_height="10.66dp"
                    android:clickable="true"
                    android:contentDescription="@null"
                    android:focusable="true"
                    android:padding="2dp"
                    android:src="@drawable/droparrow" />
            </LinearLayout>

            <!-- 可收起内容区 -->
            <LinearLayout
                android:id="@+id/rightPanelBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 定位地图卡片 -->
                <FrameLayout
                    android:id="@+id/mapCardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="124dp"
                    android:background="@android:color/transparent">

                    <com.capstone.excavator.MapView
                        android:id="@+id/mapView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"

                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp"
                        android:layout_marginBottom="8dp" />

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </eightbitlab.com.blurview.BlurView>

    <com.capstone.excavator.SpeedDirectionIndicatorView
        android:id="@+id/rightSpeedIndicator"
        android:layout_width="91.11dp"
        android:layout_height="82.22dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="245dp"
        android:layout_marginEnd="28.44dp"
        android:layout_marginBottom="0dp" />

    <com.capstone.excavator.SpeedDirectionIndicatorView
        android:id="@+id/leftSpeedIndicator"
        android:layout_width="91.11dp"
        android:layout_height="82.22dp"
        android:layout_gravity="start|top"
        android:layout_marginStart="28.44dp"
        android:layout_marginTop="245dp"
        android:layout_marginBottom="0dp" />

    <!-- ==================== 底部覆盖层 ==================== -->
    <com.capstone.excavator.BottomBarView
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

    <com.capstone.excavator.MotionModeSegmentView
        android:id="@+id/motionModeSegment"
        android:layout_width="37.33dp"
        android:layout_height="39.11dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="29dp"
        android:layout_marginBottom="97dp"
        android:elevation="12dp" />

    <!-- MotionModeSegmentView mode = findViewById(R.id.motionModeSegment);
mode.setSelectedIndex(MotionModeSegmentView.INDEX_CHASSIS);
mode.setOnIndexChangeListener(idx -> {
    // 联机协议、UDP 等
}); -->

    <com.capstone.excavator.LeftActivityPanelView
        android:layout_width="24.88dp"
        android:layout_height="match_parent"
        android:layout_gravity="start|top" />

    <com.capstone.excavator.RightActivityPanelView
        android:layout_width="24.88dp"
        android:layout_height="match_parent"
        android:layout_gravity="end|top" />

    <!-- ==================== 悬浮展开按钮（bar 收起时显示） ==================== -->
    <TextView
        android:id="@+id/btnFloatingToggle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:background="@drawable/chip_bg"
        android:clickable="true"
        android:elevation="6dp"
        android:focusable="true"
        android:gravity="center"
        android:text="▲"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:visibility="gone" />

    <!-- ==================== Header Bar ==================== -->
    <!-- HeaderBarView inflates view_header_bar.xml, owns the clock internally -->
    <com.capstone.excavator.HeaderBarView
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:elevation="10dp" />

    <!-- ==================== 急停全屏覆盖层（默认隐藏，按下急停按钮后显示） ==================== -->
    <com.capstone.excavator.EmergencyStopOverlayView
        android:id="@+id/emergencyStopOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="40dp"
        android:visibility="gone" />

    <!-- ==================== 通用二次确认弹窗（默认隐藏） ==================== -->
    <com.capstone.excavator.ConfirmDialogView
        android:id="@+id/confirmDialog"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="50dp"
        android:visibility="gone" />

    <!-- ==================== 通用内联 Toast（默认隐藏） ==================== -->
    <com.capstone.excavator.InlineToastView
        android:id="@+id/inlineToast"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="51dp"
        android:visibility="gone" />

</FrameLayout>
