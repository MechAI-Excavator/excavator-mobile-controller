<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ==================== 全屏视频层（底层背景） ==================== -->
    <!-- 包一层 BlurTarget，让 dock 按钮可以把这里的内容（视频 / 占位图）做毛玻璃 -->
    <eightbitlab.com.blurview.BlurTarget
        android:id="@+id/blurTarget"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF0A">

        <!-- 视频画面（16:9 居中全屏） -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="730dp"
            android:layout_height="match_parent">

            <com.skydroid.fpvplayer.FPVWidget
                android:id="@+id/fpvWidget"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="#FF000000"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="16:9"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0"
                tools:ignore="ContentDescription" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 无信号占位图（最顶层，offline 时覆盖视频） -->
        <FrameLayout
            android:id="@+id/videoPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/with_no_live_video"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

        </FrameLayout>

    </eightbitlab.com.blurview.BlurTarget>

    <!-- 顶部居中：LIVE 状态胶囊（在急停按钮下方，不属于 HeaderBar） -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/livePillBlur"
        android:layout_width="76dp"
        android:layout_height="16.66dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="50dp"
        android:background="@drawable/live_pill_bg"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <View
                android:id="@+id/livePillDot"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/live_dot_red" />

            <TextView
                android:id="@+id/livePillText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="实时 · 主相机"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:includeFontPadding="false"
                android:letterSpacing="0.02" />

        </LinearLayout>

    </eightbitlab.com.blurview.BlurView>

    <!-- ==================== 左侧覆盖层：机械臂姿态卡片（毛玻璃底） ==================== -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/postureCardBlur"
        android:layout_width="165dp"
        android:layout_height="165dp"
        android:layout_gravity="start|top"
        android:background="@drawable/map_card_bg"
        android:layout_marginStart="16dp"
        android:layout_marginTop="55dp"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:layout_marginBottom="0dp"
        android:elevation="10dp">

        <com.capstone.excavator.PostureCardView
            android:id="@+id/postureCardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </eightbitlab.com.blurview.BlurView>

    <!-- ==================== 右侧覆盖层：地图 + 驾驶舱状态（毛玻璃底） ==================== -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/rightPanelBlur"
        android:layout_width="165dp"
        android:layout_height="165dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="55dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="0dp"
        android:background="@drawable/map_card_bg"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:elevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- 顶部标题行：地图 + 收起箭头 -->
            <LinearLayout
                android:id="@+id/rightPanelHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/map_title"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textFontWeight="200" />

                <ImageView
                    android:id="@+id/rightPanelCollapseArrow"
                    android:layout_width="10.66dp"
                    android:layout_height="10.66dp"
                    android:src="@drawable/droparrow"
                    android:contentDescription="@null"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="2dp" />
            </LinearLayout>

            <!-- 可收起内容区 -->
            <LinearLayout
                android:id="@+id/rightPanelBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 定位地图卡片 -->
                <FrameLayout
                    android:id="@+id/mapCardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="124dp"
                    android:background="@android:color/transparent">

            <com.capstone.excavator.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="8dp" />

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </eightbitlab.com.blurview.BlurView>

    <!-- ==================== 底部覆盖层 ==================== -->
    <com.capstone.excavator.BottomBarView
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

    <!-- ==================== 悬浮展开按钮（bar 收起时显示） ==================== -->
    <TextView
        android:id="@+id/btnFloatingToggle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:background="@drawable/chip_bg"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="▲"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:elevation="6dp"
        android:visibility="gone" />

    <!-- ==================== Header Bar ==================== -->
    <!-- HeaderBarView inflates view_header_bar.xml, owns the clock internally -->
    <com.capstone.excavator.HeaderBarView
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:elevation="10dp" />

    <!-- ==================== 急停全屏覆盖层（默认隐藏，按下急停按钮后显示） ==================== -->
    <com.capstone.excavator.EmergencyStopOverlayView
        android:id="@+id/emergencyStopOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="40dp"
        android:visibility="gone" />

</FrameLayout>
