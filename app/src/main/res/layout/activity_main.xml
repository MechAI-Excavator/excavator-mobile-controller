<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ==================== 全屏视频层（底层背景） ==================== -->
    <eightbitlab.com.blurview.BlurTarget
        android:id="@+id/blurTarget"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF0A">

        <!-- 视频层：内容由 ViewStub 在代码里用「恢复物理 density」的 Context inflate，见 MainActivity#inflateFpvVideoLayerUnscaled -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ViewStub
                android:id="@+id/fpvLayerStub"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:inflatedId="@+id/fpvLayerRoot"
                android:layout="@layout/include_fpv_video_layer"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </eightbitlab.com.blurview.BlurTarget>

    <!-- 姿态卡片右侧：LIVE 状态胶囊（与 postureCardBlur 顶对齐） -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/livePillBlur"
        android:layout_width="wrap_content"
        android:layout_height="16.66dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="210dp"
        android:layout_marginTop="55dp"
        android:background="@drawable/live_pill_bg"
        android:clipToOutline="true"
        android:elevation="8dp"
        android:outlineProvider="background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingTop="1dp"
            android:paddingEnd="10dp"
            android:paddingBottom="1dp">

            <View
                android:id="@+id/livePillDot"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/live_dot_red" />

            <TextView
                android:id="@+id/livePillText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:letterSpacing="0.02"
                android:text="实时"
                android:textColor="#FFFFFF"
                android:textSize="8sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:letterSpacing="0.02"
                android:text=" · 主相机"
                android:textColor="#7AFFFFFF"
                android:textSize="8sp" />

        </LinearLayout>

    </eightbitlab.com.blurview.BlurView>

    <!-- 左侧竖条 + 横向中心度量条（与姿态卡片顶对齐留白） -->
    <FrameLayout
        android:id="@+id/referencePointTitleBar"
        android:layout_width="match_parent"
        android:layout_height="33dp"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="55dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:src="@drawable/back_title" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="9.5dp"
            android:includeFontPadding="false"
            android:text="参考点: 中斗尖"
            android:textColor="#FFFFFF"
            android:textSize="6.5sp" />
    </FrameLayout>


    <com.capstone.excavator.CenterActivityPanelView
        android:id="@+id/centerActivityPanelView"
        android:layout_width="524dp"
        android:layout_height="20dp"
        android:layout_gravity="center|top"
        android:layout_marginTop="55dp"
        app:centerGaugeRangeMax="1" />

    <!-- ==================== riseSpeedBlur ==================== -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/riseSpeedBlur"
        android:layout_width="145dp"
        android:layout_height="52dp"
        android:layout_gravity="center|top"
        android:layout_marginTop="55dp"
        android:layout_marginBottom="0dp"
        android:background="@drawable/map_card_bg"
        android:clipToOutline="true"
        android:elevation="10dp"
        android:outlineProvider="background">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="29.77dp"
                android:layout_marginTop="5dp"
                android:layout_height="41.77dp"
                android:contentDescription="@null"
                android:src="@drawable/rise_speed_icon" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:baselineAligned="true"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="35"
                    android:textColor="#FFFFFF"
                    android:textSize="36.44sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:includeFontPadding="false"
                    android:text="cm"
                    android:textColor="#FFFFFF"
                    android:textSize="10.66sp" />
            </LinearLayout>
        </LinearLayout>


    </eightbitlab.com.blurview.BlurView>
    <!-- ==================== centerCapsuleSpeedDirection ==================== -->
    <LinearLayout
        android:id="@+id/centerCapsuleSpeedDirectionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="100dp"
        android:gravity="center_horizontal"
        android:orientation="horizontal">

        <com.capstone.excavator.CapsuleSpeedDirectionView
            android:id="@+id/centerCapsuleSpeedDirection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- ==================== 左侧覆盖层：机械臂姿态卡片（毛玻璃底） ==================== -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/postureCardBlur"
        android:layout_width="165dp"
        android:layout_height="165dp"
        android:layout_gravity="start|top"
        android:layout_marginStart="28.44dp"
        android:layout_marginTop="55dp"
        android:layout_marginBottom="0dp"
        android:background="@drawable/map_card_bg"
        android:clipToOutline="true"
        android:elevation="10dp"
        android:outlineProvider="background">

        <com.capstone.excavator.PostureCardView
            android:id="@+id/postureCardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </eightbitlab.com.blurview.BlurView>

    <!-- ==================== 右侧覆盖层：地图 + 驾驶舱状态（毛玻璃底） ==================== -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/rightPanelBlur"
        android:layout_width="165dp"
        android:layout_height="165dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="55dp"
        android:layout_marginEnd="28.44dp"
        android:layout_marginBottom="0dp"
        android:background="@drawable/map_card_bg"
        android:clipToOutline="true"
        android:elevation="10dp"
        android:outlineProvider="background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- 顶部标题行：地图 + 收起箭头 -->
            <LinearLayout
                android:id="@+id/rightPanelHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/map_title"
                    android:textColor="#FFFFFF"
                    android:textFontWeight="200"
                    android:textSize="11sp" />

                <ImageView
                    android:id="@+id/rightPanelCollapseArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:clickable="true"
                    android:contentDescription="@null"
                    android:focusable="true"
                    android:padding="8dp"
                    android:src="@drawable/droparrow" />
            </LinearLayout>

            <!-- 可收起内容区 -->
            <LinearLayout
                android:id="@+id/rightPanelBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 定位地图卡片：内缩 + 圆角描边，黑色天地图与右侧 BlurView 毛玻璃衔接 -->
                <FrameLayout
                    android:id="@+id/mapCardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="124dp"
                    android:background="@android:color/transparent"
                    >

                    <com.capstone.excavator.ExcavatorMapWeb
                        android:id="@+id/mapView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </eightbitlab.com.blurview.BlurView>

    <com.capstone.excavator.SpeedDirectionIndicatorView
        android:id="@+id/rightSpeedIndicator"
        android:layout_width="120dp"
        android:layout_height="82.22dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="245dp"
        android:layout_marginEnd="60.44dp"
        android:layout_marginBottom="0dp" />

    <com.capstone.excavator.SpeedDirectionIndicatorView
        android:id="@+id/leftSpeedIndicator"
        android:layout_width="120dp"
        android:layout_height="82.22dp"
        android:layout_gravity="start|top"
        android:layout_marginStart="60.44dp"
        android:layout_marginTop="245dp"
        android:layout_marginBottom="0dp" />

    <!-- ==================== 底部覆盖层 ==================== -->
    <com.capstone.excavator.BottomBarView
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

    <com.capstone.excavator.MotionModeSegmentView
        android:id="@+id/motionModeSegment"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="29dp"
        android:layout_marginBottom="97dp"
        android:elevation="12dp" />

    <!-- MotionModeSegmentView mode = findViewById(R.id.motionModeSegment);
mode.setSelectedIndex(MotionModeSegmentView.INDEX_CHASSIS);
mode.setOnIndexChangeListener(idx -> {
    // 联机协议、UDP 等
}); -->

    <!-- 左侧竖条：本处为唯一 LeftActivityPanelView，勿在其它层级再嵌一份（会 duplicate @id/leftActivityGauge，findViewById 会命中错误实例） -->
    <com.capstone.excavator.LeftActivityPanelView
        android:id="@+id/leftActivityPanel"
        android:layout_width="24.88dp"
        android:layout_height="match_parent"
        android:layout_gravity="start|top" />

    <com.capstone.excavator.RightActivityPanelView
        android:id="@+id/rightActivityPanel"
        android:layout_width="24.88dp"
        android:layout_height="match_parent"
        android:layout_gravity="end|top" />

    <!-- 垂直独立进度条（VerticalActivityPanelView），37.33×172.44dp，左侧 28.44dp 偏移，顶部 245dp -->
    <com.capstone.excavator.VerticalActivityPanelView
        android:id="@+id/verticalActivityPanelLeft"
        android:layout_width="37.33dp"
        android:layout_height="172.44dp"
        android:layout_gravity="start|top"
        android:layout_marginStart="28.44dp"
        android:layout_marginTop="245dp" />


    <!-- 垂直独立进度条（VerticalActivityPanelView），37.33×172.44dp，左侧 28.44dp 偏移，顶部 245dp -->
    <com.capstone.excavator.VerticalActivityPanelView
        android:id="@+id/verticalActivityPanelRight"
        android:layout_width="37.33dp"
        android:layout_height="172.44dp"
        android:layout_gravity="end|top"
        android:layout_marginEnd="28.44dp"
        android:layout_marginTop="245dp" />

    <!-- ==================== Header Bar ==================== -->
    <!-- HeaderBarView inflates view_header_bar.xml, owns the clock internally -->
    <com.capstone.excavator.HeaderBarView
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:elevation="10dp" />

    <!-- ==================== 急停全屏覆盖层（默认隐藏，按下急停按钮后显示） ==================== -->
    <com.capstone.excavator.EmergencyStopOverlayView
        android:id="@+id/emergencyStopOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="40dp"
        android:visibility="gone" />

    <!-- ==================== 通用二次确认弹窗（默认隐藏） ==================== -->
    <com.capstone.excavator.ConfirmDialogView
        android:id="@+id/confirmDialog"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="50dp"
        android:visibility="gone" />

    <!-- ==================== 通用内联 Toast（默认隐藏） ==================== -->
    <com.capstone.excavator.InlineToastView
        android:id="@+id/inlineToast"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="51dp"
        android:visibility="gone" />

</FrameLayout>
