<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ==================== 全屏视频层（底层背景） ==================== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF0A">

        <!-- 视频画面（16:9 居中全屏） -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="730dp"
            android:layout_height="match_parent">

            <com.skydroid.fpvplayer.FPVWidget
                android:id="@+id/fpvWidget"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="#FF000000"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="16:9"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0"
                tools:ignore="ContentDescription" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 无信号占位图（最顶层，offline 时覆盖视频） -->
        <LinearLayout
            android:id="@+id/videoPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.25"
                android:text="🚧"
                android:textSize="64sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:letterSpacing="0.2"
                android:text="EXCAVATOR CAM"
                android:textColor="#000000"
                android:textColorLink="#070505"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="No Video Signal"
                android:textColorLink="#070505"
                android:textColor="#22FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

    </FrameLayout>

    <!-- ==================== 左侧覆盖层：机械臂姿态卡片 ==================== -->
    <com.capstone.excavator.PostureCardView
        android:id="@+id/postureCardView"
        android:layout_width="165dp"
        android:layout_height="wrap_content"
        android:layout_gravity="start|top"
        android:layout_marginStart="16dp"
        android:layout_marginTop="55dp" 
        />

    <!-- ==================== 右侧覆盖层：地图 + 驾驶舱状态（竖向堆叠） ==================== -->
    <LinearLayout
        android:layout_width="165dp"
        android:layout_height="wrap_content"
        android:layout_gravity="end|top"
        android:layout_marginTop="55dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        android:elevation="10dp">

        <!-- 定位地图卡片 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="124dp"
            android:background="@drawable/map_card_bg"
            android:clipToOutline="true"
            android:outlineProvider="background">

            <com.capstone.excavator.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="25dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|top"
                android:layout_margin="12dp"
                android:text="@string/map_title"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

        </FrameLayout>


    <!-- ==================== 右侧覆盖层：驾驶舱状态 ==================== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/map_card_bg"
            android:clipToOutline="true"
            android:outlineProvider="background">

        <!-- 驾驶舱状态卡片（与地图样式一致，8dp 间距） -->
        <com.capstone.excavator.CarbinStatusView
            android:id="@+id/carbinStatusView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|top"
                android:layout_margin="12dp"
                android:text="@string/carbin_status_title"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

        </FrameLayout>
    </LinearLayout>

    <!-- ==================== 底部覆盖层 ==================== -->
    <com.capstone.excavator.BottomBarView
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

    <!-- ==================== 悬浮展开按钮（bar 收起时显示） ==================== -->
    <TextView
        android:id="@+id/btnFloatingToggle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:background="@drawable/chip_bg"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="▲"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:elevation="6dp"
        android:visibility="gone" />

    <!-- ==================== Header Bar ==================== -->
    <!-- HeaderBarView inflates view_header_bar.xml, owns the clock internally -->
    <com.capstone.excavator.HeaderBarView
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:elevation="10dp" />

</FrameLayout>
