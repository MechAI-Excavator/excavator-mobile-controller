<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tooltipRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="2dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Arrow container: arrow fixed on the right -->
        <FrameLayout
            android:id="@+id/tooltipArrowContainer"
            android:layout_width="280dp"
            android:layout_height="8dp">

            <ImageView
                android:id="@+id/tooltipArrow"
                android:layout_width="14dp"
                android:layout_height="8dp"
                android:contentDescription="@null"
                android:src="@drawable/tooltip_arrow_up" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/tooltipCard"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:background="@drawable/tooltip_card_bg"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/tooltipClose"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|end"
                android:contentDescription="@null"
                android:src="@drawable/closebtn" />

            <TextView
                android:id="@+id/tooltipText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginEnd="26dp"
                android:text="这里是帮助提示内容，你可以在此解释该页面的参数含义。"
                android:textColor="#FF111827"
                android:textSize="12sp"
                android:lineSpacingExtra="3dp" />
        </FrameLayout>
    </LinearLayout>

</FrameLayout>

