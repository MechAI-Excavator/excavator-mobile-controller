<?xml version="1.0" encoding="utf-8"?>
<!-- 修坡作业设置 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F4FF"
    android:orientation="vertical">
    <!-- 顶部导航栏 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="#00000000"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <LinearLayout
            android:id="@+id/btnLevelBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/arrow_back" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="返回"
                android:textColor="#FF2563EB"
                android:textSize="12sp" />
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="修坡作业设置"
            android:textColor="#FF111827"
            android:textSize="14sp"
            android:textStyle="bold" />
        <ImageView
            android:id="@+id/btnLevelHelp"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/answer_icon" />
    </RelativeLayout>
    <!-- 主内容区：左 / 右 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="40dp"
        android:paddingTop="4dp"
        android:paddingEnd="40dp"
        android:paddingBottom="20dp"
        android:weightSum="100">
        <!-- ── 右侧预览面板（交换后在左侧显示） ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="14dp"
            android:layout_weight="50"
            android:background="@drawable/card_light_bg"
            android:orientation="vertical"
            android:padding="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Step 3 确定C点"
                android:textColor="#FF111827"
                android:textSize="16sp"
                android:textStyle="bold" />
                <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="C点"
                android:textColor="#FF111827"
                android:textSize="16sp"
                android:textStyle="normal" />
                  <!-- 参考点选择卡片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <!-- 左斗尖 -->
                    <LinearLayout
                        android:id="@+id/cardRefLeftA"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/level_card_normal_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/left_point" />
                        <TextView
                            android:id="@+id/tvRefLeftA"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="左斗尖"
                            android:textColor="#FF9CA3AF"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                    <!-- 中斗尖 -->
                    <LinearLayout
                        android:id="@+id/cardRefMiddleA"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/level_card_selected_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/middle_point" />
                        <TextView
                            android:id="@+id/tvRefMiddleA"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="中斗尖"
                            android:textColor="#FF2563EB"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                    <!-- 右斗尖 -->
                    <LinearLayout
                        android:id="@+id/cardRefRightA"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_weight="1"
                        android:background="@drawable/level_card_normal_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/right_point" />
                        <TextView
                            android:id="@+id/tvRefRightA"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="右斗尖"
                            android:textColor="#FF9CA3AF"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="坡比(%)："
                            android:textColor="#FF374151"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:text=":"
                            android:textColor="#FF9CA3AF"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:text="1:"
                            android:textColor="#FF9CA3AF"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tvAbDistance"
                            android:layout_width="215dp"
                            android:layout_height="36dp"
                            android:background="@drawable/level_input_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical|end"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:text="0.38"
                            android:textColor="#FF9CA3AF"
                            android:textSize="14sp" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="垂高(H)"
                            android:textColor="#FF374151"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:text=":"
                            android:textColor="#FF9CA3AF"
                            android:textSize="14sp" />

                        <LinearLayout
                            style="@style/InputWithSuffixContainer"
                            android:layout_width="280dp"
                            android:layout_height="36dp">

                            <TextView
                                android:id="@+id/tvAbLift"
                                style="@style/InputWithSuffixValue"
                                android:clickable="true"
                                android:focusable="true"
                                android:text="0.38"
                                android:textColor="#FF9CA3AF"
                                android:textSize="14sp" />

                            <TextView
                                style="@style/InputSuffixUnit"
                                android:text="m" />
                        </LinearLayout>
                    </LinearLayout>
                            <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="平距(L)"
                                    android:textColor="#FF374151"
                                    android:textSize="14sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:text=":"
                            android:textColor="#FF9CA3AF"
                            android:textSize="14sp" />

                                <LinearLayout
                                    style="@style/InputWithSuffixContainer"
                                    android:layout_width="280dp"
                                    android:layout_height="36dp">

                                    <TextView
                                        android:id="@+id/tvAbHeightDiff"
                                        style="@style/InputWithSuffixValue"
                                        android:layout_width="214dp"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:text="0.38"
                                        android:textColor="#FF9CA3AF"
                                        android:textSize="14sp" />

                                    <TextView
                                        style="@style/InputSuffixUnit"
                                        android:text="m" />
                                </LinearLayout>
                    </LinearLayout>
               <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:text="坡面方向"
                android:textColor="#FF374151"
                android:textSize="14sp" />
                <!-- 坡面方向：左侧 / 右侧 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/btnSlopeDirLeft"
                        android:layout_width="84dp"
                        android:layout_height="35dp"
                        android:background="@drawable/slope_dir_unselected_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="左侧"
                        android:textColor="#FF6B7280"
                        android:textSize="14sp" />
                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />
                    <TextView
                        android:id="@+id/btnSlopeDirRight"
                        android:layout_width="84dp"
                        android:layout_height="35dp"
                        android:background="@drawable/slope_dir_selected_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="右侧"
                        android:textColor="#FF2563EB"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
        </LinearLayout>
        <!-- ── 左侧面板（交换后在右侧显示） ── -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="50"
            android:background="@drawable/card_light_bg"
            android:fillViewport="false"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <!-- Step1 标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="预览"
                    android:textColor="#FF111827"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="350dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="vertical">
                    <!-- t1 -->
                    <LinearLayout
                        android:id="@+id/cardDitchSquare"
                        android:layout_width="match_parent"
                        android:layout_height="350dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/slope_step3" />
                    </LinearLayout>
                </LinearLayout>
                <!-- 上一步 / 下一步 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/btnDitchPrev"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/button_outline_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="上一步"
                        android:textColor="#FF6B7280"
                        android:textSize="14sp" />
                    <Space
                        android:layout_width="14dp"
                        android:layout_height="1dp" />
                    <TextView
                        android:id="@+id/btnSlopeRepairNext"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/button_blue_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="下一步"
                        android:textColor="#FFFFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
    <!-- Step 进度（底部）：当前为第 1 步 -->
    <LinearLayout
        android:id="@+id/levelStepBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">
        <View
            android:id="@+id/step1"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_active" />
        <Space
            android:layout_width="30dp"
            android:layout_marginEnd="0dp"
            android:layout_marginStart="0dp"
            android:layout_height="1dp" />
        <View
            android:id="@+id/step2"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_inactive" />
               <Space
            android:layout_width="30dp"
            android:layout_marginEnd="0dp"
            android:layout_marginStart="0dp"
            android:layout_height="1dp" />
        <View
            android:id="@+id/step3"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_inactive" />
               <Space
            android:layout_width="30dp"
            android:layout_marginEnd="0dp"
            android:layout_marginStart="0dp"
            android:layout_height="1dp" />
        <View
            android:id="@+id/step4"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_inactive" />
    </LinearLayout>
</LinearLayout>
