<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:layout_height="wrap_content"
    tools:layout_width="wrap_content"
    tools:parentTag="com.capstone.excavator.CapsuleSpeedDirectionView">

    <eightbitlab.com.blurview.BlurView
        android:id="@+id/capsuleSpeedPillBlur"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/capsule_speed_pill_bg"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:duplicateParentState="true"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:baselineAligned="false"
            android:duplicateParentState="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="6dp"
            android:paddingEnd="18dp"
            android:paddingBottom="6dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:duplicateParentState="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/capsuleArrowForward"
                    android:layout_width="17.7dp"
                    android:layout_height="30dp"
                    android:contentDescription="@null"
                    android:duplicateParentState="true"
                    android:scaleType="fitXY"
                    android:src="@drawable/capsule_arrow_forward_glyph"
                    android:tint="@color/capsule_arrow_forward_tint"
                    android:tintMode="src_in" />

                <View
                    android:id="@+id/capsuleDivider"
                    android:layout_width="2.5dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/capsule_divider_bg"
                    android:duplicateParentState="true" />

                <ImageView
                    android:id="@+id/capsuleArrowBack"
                    android:layout_width="17.7dp"
                    android:layout_height="30dp"
                    android:contentDescription="@null"
                    android:duplicateParentState="true"
                    android:scaleType="fitXY"
                    android:src="@drawable/capsule_arrow_backward_glyph"
                    android:tint="@color/capsule_arrow_back_tint"
                    android:tintMode="src_in" />
            </LinearLayout>

            <TextView
                android:id="@+id/capsuleSpeedValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:includeFontPadding="false"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="36dp"
                android:textStyle="bold" />
        </LinearLayout>
    </eightbitlab.com.blurview.BlurView>

</merge>
