<?xml version="1.0" encoding="utf-8"?>
<!--
  首次启动配置弹窗。
  全屏 Dialog 承载居中卡片；交互控件用 TextView，避免 Material3 改写按钮颜色。
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#66000000">

    <LinearLayout
        android:layout_width="365dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/first_run_config_card_bg"
        android:orientation="vertical"
        android:paddingStart="37.33dp"
        android:paddingTop="27.25dp"
        android:paddingEnd="37.33dp"
        android:paddingBottom="27.25dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="首次启动配置"
            android:textColor="#FF000000"
            android:textSize="21.33sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10.6dp"
            android:includeFontPadding="false"
            android:lineSpacingExtra="5.33dp"
            android:text="检测到系统首次运行，已识别到RTK与IMU，是否立即配置机器参数以获得最佳引导精度?"
            android:textColor="#FF000000"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="41.33dp"
            android:layout_marginTop="21.33dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnFirstRunSkip"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6.67dp"
                android:layout_weight="0.8"
                android:background="@drawable/first_run_config_outline_btn_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="跳过"
                android:textColor="#FF0052FF"
                android:textSize="14.22dp" />

            <LinearLayout
                android:id="@+id/btnFirstRunConfigure"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:background="@drawable/first_run_config_filled_btn_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="17.77dp"
                    android:layout_height="17.77dp"
                    android:src="@drawable/setting_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6.67dp"
                    android:includeFontPadding="false"
                    android:text="配置参数"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14.22dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
