<?xml version="1.0" encoding="utf-8"?>
<!--
  首次运行语言选择页（全屏覆盖）。
  按钮用 FrameLayout+TextView 避免 Material3 覆盖背景色；active 时右下角显示 badge。
  点击语言即立即保存并关闭。
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="44.44dp"
        android:layout_marginStart="64.44dp"
        android:orientation="vertical">
        <!-- 多语言标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:text="选择你的习惯语言 / 請選擇你的習慣語言"
            android:textColor="#1A1A1A"
            android:textSize="28.44sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.2" />

        <!-- 副标题 (English) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:text="Please select your preferred language"
            android:textColor="#6B7280"
            android:textSize="21.33sp" />
    </LinearLayout>

    <!-- 内容：垂直居中，宽度固定 300dp -->
    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical">

        <!-- 语言按钮组 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical">

            <!-- 简体中文（默认选中） -->
            <FrameLayout
                android:id="@+id/btnPickZhHans"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/lang_chip_selected_bg"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="简体中文"
                    android:textColor="#FFFFFFFF"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="bottom|end"
                    android:src="@drawable/selected_icon"
                    android:visibility="visible" />
            </FrameLayout>

            <!-- 繁體中文 -->
            <FrameLayout
                android:id="@+id/btnPickZhHant"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/lang_chip_unselected_bg"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="繁體中文"
                    android:textColor="#FF9CA3AF"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="bottom|end"
                    android:src="@drawable/selected_icon"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- English -->
            <FrameLayout
                android:id="@+id/btnPickEn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/lang_chip_unselected_bg"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="English"
                    android:textColor="#FF9CA3AF"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="bottom|end"
                    android:src="@drawable/selected_icon"
                    android:visibility="gone" />
            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
