<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── 顶部标题行：标题 + 2D/3D 切换 ── -->
    <LinearLayout
        android:id="@+id/postureHeaderRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6.25dp"
        android:paddingBottom="6.25dp"
        android:clickable="true"
        android:focusable="true"
        >
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/posture_card_title"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textFontWeight="200" />

        <!-- 2D / 3D 切换胶囊按钮 -->
        <eightbitlab.com.blurview.BlurView
            android:id="@+id/blurModeToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@drawable/mode_toggle_bg"
            android:padding="0.5dp"
            android:gravity="center_vertical">
        <LinearLayout
            android:id="@+id/modeToggleContainer"
            android:layout_width="50dp"
            android:layout_height="18dp"
            android:orientation="horizontal"
            android:padding="2dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btn2D"
                android:layout_width="22dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="2D"
                android:textColor="#FFFFFF"
                android:textSize="7dp"
                android:textStyle="bold"
                android:background="@drawable/mode_toggle_selected_bg"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn3D"
                android:layout_width="22dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="3D"
                android:textColor="#66545454"
                android:textSize="7dp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
        </eightbitlab.com.blurview.BlurView>

        <ImageView
            android:id="@+id/postureCollapseArrow"
            android:layout_width="10.66dp"
            android:layout_height="10.66dp"
            android:src="@drawable/droparrow"
            android:contentDescription="@null"
            android:clickable="true"
            android:focusable="true"
            android:padding="2dp" />

    </LinearLayout>

    <!-- 可收起内容区（收起后仅保留标题行） -->
    <LinearLayout
        android:id="@+id/postureBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── 2D 模式：Web 页面（与 3D 使用相同 bridge 数据） ── -->
        <FrameLayout
            android:id="@+id/view2D"
            android:layout_width="match_parent"
            android:layout_height="93dp"
            android:layout_gravity="bottom"
            android:layout_marginTop="13dp"
            android:layout_marginBottom="6dp"
            android:visibility="visible">

        <com.capstone.excavator.Excavator2DPostureView
            android:id="@+id/excavatorPosture2DView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        </FrameLayout>

        <!-- ── 3D 模式：WebView（2D 时隐藏，切换后显示） ── -->

        <FrameLayout
            android:id="@+id/view3D"
            android:layout_width="match_parent"
            android:layout_height="139dp"
            android:layout_marginBottom="0dp"
            android:visibility="gone">

        <com.capstone.excavator.ExcavatorPostureView
            android:id="@+id/excavatorPostureView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
        
        <ImageView
            android:layout_width="21.72dp"
            android:layout_height="19.44dp"
            android:layout_marginStart="15dp"
            android:layout_marginBottom="20dp"
            android:layout_gravity="start|bottom"
            android:src="@drawable/coordinate"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:contentDescription="@null" />
        </FrameLayout>

    </LinearLayout>

</merge>
