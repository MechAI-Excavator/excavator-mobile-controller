<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F4FF"
    android:orientation="vertical">
    <!-- 主内容区：左 / 右 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="#00000000"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <LinearLayout
            android:id="@+id/btnLevelBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/arrow_back" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="返回"
                android:textColor="#FF2563EB"
                android:textSize="12sp" />
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="挖沟作业设置"
            android:textColor="#FF111827"
            android:textSize="14sp"
            android:textStyle="bold" />
        <ImageView
            android:id="@+id/btnLevelHelp"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/answer_icon" />
    </RelativeLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="40dp"
        android:paddingTop="4dp"
        android:paddingEnd="40dp"
        android:paddingBottom="20dp"
        android:weightSum="100">
        <!-- ── 左侧面板 ── -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="14dp"
            android:layout_weight="50"
            android:background="@drawable/card_light_bg"
            android:fillViewport="false"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <!-- Step1 标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="Step 1 选择挖沟沟型 "
                    android:textColor="#FF111827"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="vertical">
                    <!-- t1 -->
                    <LinearLayout
                        android:id="@+id/cardDitchSquare"
                        android:layout_width="match_parent"
                        android:layout_height="178dp"
                        android:background="@drawable/level_card_normal_bg"
                        android:clickable="true"
                        android:layout_marginBottom="8dp"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvDitchSquare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:text="方形沟"
                            android:textColor="#FF9CA3AF"
                            android:textSize="14dp" />
                        <ImageView
                            android:layout_width="175dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/square_ditch" />
                    </LinearLayout>
                    <!-- t2 -->
                    <LinearLayout
                        android:id="@+id/cardDitchTrapezoid"
                        android:layout_width="match_parent"
                        android:layout_height="178dp"
                        android:background="@drawable/level_card_normal_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvDitchTrapezoid"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:text="梯形沟"
                            android:textColor="#FF9CA3AF"
                            android:textSize="14dp" />
                        <ImageView
                            android:layout_width="175dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/trapezoid_ditch" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
        <!-- ── 右侧预览面板 ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="50"
            android:background="@drawable/card_light_bg"
            android:orientation="vertical"
            android:padding="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Step 2 参考点"
                android:textColor="#FF111827"
                android:textSize="16sp"
                android:textStyle="bold" />
                <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="A点"
                android:textColor="#FF111827"
                android:textSize="16sp"
                android:textStyle="normal" />
                  <!-- 参考点选择卡片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <!-- 左斗尖 -->
                    <LinearLayout
                        android:id="@+id/cardRefLeftA"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/level_card_normal_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/left_point" />
                        <TextView
                            android:id="@+id/tvRefLeftA"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="左斗尖"
                            android:textColor="#FF9CA3AF"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                    <!-- 中斗尖 -->
                    <LinearLayout
                        android:id="@+id/cardRefMiddleA"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/level_card_selected_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/middle_point" />
                        <TextView
                            android:id="@+id/tvRefMiddleA"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="中斗尖"
                            android:textColor="#FF2563EB"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                    <!-- 右斗尖 -->
                    <LinearLayout
                        android:id="@+id/cardRefRightA"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_weight="1"
                        android:background="@drawable/level_card_normal_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/right_point" />
                        <TextView
                            android:id="@+id/tvRefRightA"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="右斗尖"
                            android:textColor="#FF9CA3AF"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                </LinearLayout>
                <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="B点"
                android:textColor="#FF111827"
                android:textSize="16sp"
                android:textStyle="normal" />
                  <!-- 参考点选择卡片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <!-- 左斗尖 -->
                    <LinearLayout
                        android:id="@+id/cardRefLeftB"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/level_card_normal_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/left_point" />
                        <TextView
                            android:id="@+id/tvRefLeftB"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="左斗尖"
                            android:textColor="#FF9CA3AF"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                    <!-- 中斗尖 -->
                    <LinearLayout
                        android:id="@+id/cardRefMiddleB"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/level_card_selected_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/middle_point" />
                        <TextView
                            android:id="@+id/tvRefMiddleB"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="中斗尖"
                            android:textColor="#FF2563EB"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                    <!-- 右斗尖 -->
                    <LinearLayout
                        android:id="@+id/cardRefRightB"
                        android:layout_width="0dp"
                        android:layout_height="85dp"
                        android:layout_weight="1"
                        android:background="@drawable/level_card_normal_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-12dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/right_point" />
                        <TextView
                            android:id="@+id/tvRefRightB"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-25dp"
                            android:text="右斗尖"
                            android:textColor="#FF9CA3AF"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="AB距离"
                            android:textColor="#FF374151"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:text=":"
                            android:textColor="#FF9CA3AF"
                            android:textSize="14sp" />
                        <LinearLayout
        
                            android:layout_width="284dp"
                            android:layout_height="36dp"
                            >
                            <TextView
                                android:id="@+id/tvCurrentRef"
                                style="@style/InputWithSuffixValue"
                                android:clickable="true"
                                android:layout_marginStart="30dp"
                                android:focusable="true"
                                android:text="0.38"
                                android:textColor="#FF97A4C2"
                                android:textSize="14sp"
                                />
                            <TextView
                                style="@style/InputSuffixUnit"
                                android:text="m"
                                />
                        </LinearLayout>
                    </LinearLayout>
            <!-- 下一步按钮 -->
            <TextView
                android:id="@+id/btnLevelNext"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/button_blue_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="下一步"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
    <!-- Step 进度（底部）：当前为第 1 步 -->
    <LinearLayout
        android:id="@+id/levelStepBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">
        <View
            android:id="@+id/step1"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_active" />
        <Space
            android:layout_width="30dp"
            android:layout_marginEnd="0dp"
            android:layout_marginStart="0dp"
            android:layout_height="1dp" />
        <View
            android:id="@+id/step2"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_inactive" />
        <Space
            android:layout_width="30dp"
            android:layout_marginEnd="0dp"
            android:layout_marginStart="0dp"
            android:layout_height="1dp" />
        <View
            android:id="@+id/step2"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_inactive" />
               <Space
            android:layout_width="30dp"
            android:layout_marginEnd="0dp"
            android:layout_marginStart="0dp"
            android:layout_height="1dp" />
        <View
            android:id="@+id/step2"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/level_step_inactive" />
    </LinearLayout>
</LinearLayout>
