<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 整个底部覆盖层完全透明，仅由三段式控件构成：左摇杆 / 中央 dock / 右摇杆 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp">

        <!-- ── 左摇杆：毛玻璃圆角矩形 + 透明圆环 + 白色光点 ──────── -->
        <eightbitlab.com.blurview.BlurView
            android:id="@+id/blurJoystickLeft"
            android:layout_width="44.44dp"
            android:layout_height="44.44dp"
            android:layout_gravity="start|bottom"
            android:background="@drawable/dock_item_blur_bg"
            android:padding="6dp">

            <com.capstone.excavator.JoystickIndicatorView
                android:id="@+id/joystickLeft"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </eightbitlab.com.blurview.BlurView>

        <!-- ── 中央 dock：5 个动作按钮（图标 + 文本） ───────────── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|bottom"

            android:orientation="horizontal">

            <!-- 重连 -->
            <eightbitlab.com.blurview.BlurView
                android:id="@+id/btnReconnect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/dock_item_blur_bg"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                >

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="6dp">

                    <ImageView
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:contentDescription="重连"
                        android:src="@drawable/retry" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5.3dp"
                        android:text="重连"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp" />

                </LinearLayout>

            </eightbitlab.com.blurview.BlurView>

            <!-- 找平 / 挖沟 / 修坡：合并成一个大的包围盒（毛玻璃底） -->
            <eightbitlab.com.blurview.BlurView
                android:id="@+id/blurWorkGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/dock_item_blur_bg">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <LinearLayout
                        android:id="@+id/btnLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingStart="10dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="6dp">
                        

                        <ImageView
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:contentDescription="找平"
                            android:src="@drawable/icon1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5.3dp"
                            android:text="找平"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnTrench"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingStart="10dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="6dp">

                        <ImageView
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:contentDescription="挖沟"
                            android:src="@drawable/icon2" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5.3dp"
                            android:text="挖沟"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnSlope"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingStart="10dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="6dp">

                        <ImageView
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:contentDescription="修坡"
                            android:src="@drawable/icon3" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5.3dp"
                            android:text="修坡"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

            </eightbitlab.com.blurview.BlurView>

            <!-- 挖沟 -->
            <!-- <eightbitlab.com.blurview.BlurView
                android:id="@+id/btnTrench"
                android:layout_width="wrap_content"
