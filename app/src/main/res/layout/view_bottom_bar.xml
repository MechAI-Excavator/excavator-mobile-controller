                </LinearLayout>

            </eightbitlab.com.blurview.BlurView> -->

            <!-- 修坡 -->
            <!-- <eightbitlab.com.blurview.BlurView
                android:id="@+id/btnSlope"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
