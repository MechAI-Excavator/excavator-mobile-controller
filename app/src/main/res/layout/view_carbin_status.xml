<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 姿态仪：雷达底图 + 黄色光标，根据俯仰/横滚角偏移 -->
    <com.capstone.excavator.AttitudeIndicatorView
        android:id="@+id/attitudeIndicatorView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="0.5pt"
        android:src="@drawable/cabin_line"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp" />

   <!-- 驾驶舱状态 -->

    <!-- PITCH 行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginLeft="1dp"
        android:layout_marginRight="1dp"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="8dp"
        >

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="俯仰角"
             android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/tvCabinPitchAngle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#EC1111"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ROLL 行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginLeft="1dp"
        android:layout_marginRight="1dp"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="8dp"
        >

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="横滚角"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/tvCabinRollAngle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FBBF24"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>


    <!-- 经纬度 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginLeft="1dp"
        android:layout_marginRight="1dp"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="8dp"
        >

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="经纬度"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/tvCabinLatLon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#50FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

</merge>
