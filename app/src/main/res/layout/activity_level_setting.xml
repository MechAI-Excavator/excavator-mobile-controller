<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F4FF"
    android:orientation="vertical">

    <!-- 顶部导航栏 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="#00000000"
        android:layout_marginTop="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:id="@+id/btnLevelBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="＜"
                android:textColor="#FF2563EB"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="返回"
                android:textColor="#FF2563EB"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="找平作业设置"
            android:textColor="#FF111827"
            android:textSize="14sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- 主内容区：左 / 右 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:weightSum="100">

        <!-- ── 左侧面板 ── -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="47"
            android:layout_marginEnd="14dp"
            android:background="@drawable/card_light_bg"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Step1 标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="Step1 参考点"
                    android:textColor="#FF111827"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- 参考点选择卡片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- 左斗尖 -->
                    <LinearLayout
                        android:id="@+id/cardRefLeft"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/level_card_normal_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:layout_marginTop="-22dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/left_point" />

                        <TextView
                            android:id="@+id/tvRefLeft"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-30dp"
                            android:text="左斗尖"
                            android:textColor="#FF9CA3AF"
                            android:textSize="10.5sp" />
                    </LinearLayout>

                    <!-- 中斗尖 -->
                    <LinearLayout
                        android:id="@+id/cardRefMiddle"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/level_card_selected_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:layout_marginTop="-22dp"
                            android:src="@drawable/middle_point" />

                        <TextView
                            android:id="@+id/tvRefMiddle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-30dp"
                            android:text="中斗尖"
                            android:textColor="#FF2563EB"
                            android:textSize="10.5sp" />
                    </LinearLayout>

                    <!-- 右斗尖 -->
                    <LinearLayout
                        android:id="@+id/cardRefRight"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:background="@drawable/level_card_normal_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:layout_marginTop="-22dp"
                            android:src="@drawable/right_point" />

                        <TextView
                            android:id="@+id/tvRefRight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="右斗尖"
                            android:layout_marginTop="-30dp"
                            android:textColor="#FF9CA3AF"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Step2 标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Step2 目标设定"
                    android:textColor="#FF111827"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- 模式切换：高度定点 / 坐标定点 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/level_mode_group_bg"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/btnModeHeight"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@drawable/level_mode_selected_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="高度定点"
                        android:textColor="#FF2563EB"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnModeCoord"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="坐标定点"
                        android:textColor="#FF9CA3AF"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- 当前参考点（只读） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="当前参考点"
                        android:textColor="#FF374151"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:text=":"
                        android:textColor="#FF9CA3AF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvCurrentRef"
                        android:layout_width="100dp"
                        android:layout_height="36dp"
                        android:background="@drawable/level_input_bg"
                        android:gravity="center_vertical|end"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:text="0.38"
                        android:textColor="#FF9CA3AF"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="m"
                        android:textColor="#FF9CA3AF"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- 目标高度（可点击弹 Numpad） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="目标高度"
                        android:textColor="#FF374151"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:text=":"
                        android:textColor="#FF9CA3AF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvTargetHeight"
                        android:layout_width="100dp"
                        android:layout_height="36dp"
                        android:background="@drawable/level_input_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical|end"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:text="0"
                        android:textColor="#FF111827"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="m"
                        android:textColor="#FF9CA3AF"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- 填挖量（可点击弹 Numpad） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="填挖量"
                        android:textColor="#FF374151"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:text=":"
                        android:textColor="#FF9CA3AF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvFillCut"
                        android:layout_width="100dp"
                        android:layout_height="36dp"
                        android:background="@drawable/level_input_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical|end"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:text="0"
                        android:textColor="#FF111827"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="m"
                        android:textColor="#FF9CA3AF"
                        android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- ── 右侧预览面板 ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="53"
            android:background="@drawable/card_light_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="预览"
                android:textColor="#FF111827"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 预览图 + 距离标注叠加层 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/excavator_example02" />

                <!--
                  距离标注：锚定在铲斗右下区域（对应图片右侧 ~65% 横，~72% 纵）
                  layout_gravity="bottom|end" + margin 来模拟绝对定位
                -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="56dp"
                    android:layout_marginBottom="72dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- 红色双箭头竖线 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:text="↕"
                        android:textColor="#FFEF4444"
                        android:textSize="14sp" />

                    <!-- 距离数值 -->
                    <TextView
                        android:id="@+id/tvDepthLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="−0.20 m"
                        android:textColor="#FFEF4444"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </FrameLayout>

            <!-- 下一步按钮 -->
            <TextView
                android:id="@+id/btnLevelNext"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/button_blue_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="下一步"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
